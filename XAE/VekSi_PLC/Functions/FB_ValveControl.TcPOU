<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_ValveControl" Id="{83e8a007-202b-43ef-a593-2a6bab96e41d}" SpecialFunc="None">
    <Declaration><![CDATA[(*
============================================================
FUNCTION_BLOCK: FB_ValveControl
============================================================

PURPOSE
  Controls a single irrigation gate valve using TC2_MC2.
  Implements an 8-state PLCopen-compatible state machine
  that manages power, homing, position moves, halts, and
  fault recovery.

STATE MACHINE
  INIT      — Clears all flags, waits for drive ready → HOMING
  HOMING    — Executes MC_Home to find zero reference
  IDLE      — Monitors for setpoint change or homing request
  MOVING    — Executes MC_MoveAbsolute to reach target position
  HOLD      — At target; watches for new setpoint or re-home
  HALT      — Stopping via MC_Halt (operator STOP button)
  FAULT     — Latches fault code; waits for Reset command
  RESET     — Executes MC_Reset; then transitions to HOMING

SETPOINT ARBITRATION
  MQTT (lower priority): applied when MQTT_Enabled = TRUE AND
    MQTT_Setpoint changes from last known value.
  HMI (higher priority): applied on rising edge of UPDATE button.
  HMI always wins if both arrive in the same PLC cycle.
  Source output reflects who issued the most recent command.

LIBRARIES
  TC2_MC2
============================================================
*)

FUNCTION_BLOCK FB_ValveControl

VAR_IN_OUT
    Axis                : AXIS_REF;  // Must be linked to an NC axis in I/O mapping
END_VAR

VAR_INPUT
    // ── Setpoints ─────────────────────────────────────────────
    HMI_Setpoint        : REAL;             // Target position from HMI   (0.0–100.0 %)
    MQTT_Setpoint       : REAL;             // Target position from MQTT  (0.0–100.0 %)
    MQTT_Enabled        : BOOL;             // FALSE = ignore MQTT commands for this valve

    // ── Homing ────────────────────────────────────────────────
    eHomingSelection    : MC_HomingMode;    // Homing mode (MC_Direct sets position without movement)
    bHoming             : BOOL;             // Rising edge: trigger re-home sequence

    // ── Control ───────────────────────────────────────────────
    Enable              : BOOL;             // TRUE = drive powered; FALSE = de-energised
    Reset               : BOOL;             // Rising edge: clear fault and re-home
    Move_Stop           : BOOL;             // TRUE: halt movement immediately
    UPDATE              : BOOL;             // Rising edge from HMI Apply setpoint button
    ZeroPosition        : BOOL;             // Limit switch at home/zero position
	TopPosition			: BOOL;

    // ── Motion parameters ─────────────────────────────────────
    // LREAL type required — matches MC_MoveAbsolute VAR_INPUT types exactly.
    // Ref: Beckhoff Infosys → TC2_MC2 → MC_MoveAbsolute
    MoveVelocity        : LREAL;    // mm/s    — normal travel speed
    MoveAccel           : LREAL;    // mm/s²   — acceleration ramp
    MoveDecel           : LREAL;    // mm/s²   — deceleration ramp
    MoveJerk            : LREAL;    // mm/s³   — jerk limit; 0.0 = trapezoidal profile
    HomeVelocity        : LREAL;    // mm/s    — reference; actual speed set in NC Homing tab

    // ── Scaling ───────────────────────────────────────────────
    FullStroke_mm       : REAL;     // mm — axis travel at 100 % open (calibrate to hardware)
    PosTolerance        : REAL;     // %  — in-position dead-band
END_VAR

VAR_OUTPUT
    // ── Position feedback ─────────────────────────────────────
    Actual_Position     : REAL;             // Current valve opening (0.0–100.0 %)
    InPosition          : BOOL;             // TRUE when |actual - setpoint| <= PosTolerance
    rActual_mm          : LREAL;            // Raw axis position in mm
    rTarget_mm          : LREAL := 0.0;     // Active target in mm

    // ── State and source ──────────────────────────────────────
    State               : E_ValveState;     // Current state machine state (for HMI display)
    Source              : E_ValveSource;    // Who issued the last command (HMI / MQTT / NONE)

    // ── Status flags ──────────────────────────────────────────
    IsHomed             : BOOL;             // TRUE once homing completed successfully
    IsMoving            : BOOL;             // TRUE while axis is physically moving
    IsFault             : BOOL;             // TRUE while in FAULT state
    FaultCode           : UDINT;            // MC2 ErrorID — see Beckhoff error code list
END_VAR

VAR
    // ── TC2_MC2 function block instances ──────────────────────
    // Declared at FB level so they retain state between PLC cycles.
    // Ref: Beckhoff Infosys → TC2_MC2 → General Information
    fbPower             : MC_Power;
    fbHome              : MC_Home;
    fbMoveAbs           : MC_MoveAbsolute;
    fbReadPos           : MC_ReadActualPosition;
    fbHalt              : MC_Halt;
    fbReset_MC          : MC_Reset;
	fbSetPos			: MC_SetPosition;

    // ── State machine ─────────────────────────────────────────
    eState              : E_ValveState := E_ValveState.INIT;

    // ── Setpoint arbitration ──────────────────────────────────
    rActiveSetpoint     : REAL  := 0.0;
    rPrev_HMI_SP        : REAL  := -999.0;  // -999 ensures first HMI value is always applied
    rPrev_MQTT_SP       : REAL  := -999.0;  // -999 ensures first MQTT value is always applied

    // ── PLCopen Execute flags ─────────────────────────────────
    // Set TRUE on state entry → MC FB receives rising edge.
    // Set FALSE on Done/Error → FB resets, ready for next trigger.
    // Ref: PLCopen Motion Control Part 1, Section 4
    bExecHome           : BOOL;
    bExecMove           : BOOL;
    bExecReset          : BOOL;
    bExecHalt           : BOOL;

    // ── Edge detection ────────────────────────────────────────
    rtReset             : R_TRIG;
    rtUpdate            : F_TRIG;   // Rising edge on HMI Apply button
    rtZeroPosition      : R_TRIG; //not used
    rtHoming            : R_TRIG;

    // ── Internal working variables ────────────────────────────
    bAxisReady          : BOOL;
    MoveDone            : BOOL;
    tempSetpoint        : REAL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ============================================================
// SECTION 1 — EDGE DETECTION
// R_TRIG output Q is TRUE for exactly one PLC cycle on a
// rising edge. Ensures button presses trigger exactly once.
// ============================================================
rtReset(CLK := Reset);
rtUpdate(CLK := UPDATE);
rtHoming(CLK := bHoming);

// ReadStatus must be called every cycle to keep Axis state current
Axis.ReadStatus();


// ============================================================
// SECTION 2 — SETPOINT ARBITRATION & SOURCE TRACKING
//
// Priority (lowest to highest):
//   1. MQTT: applied when MQTT_Enabled=TRUE and value has changed
//   2. HMI:  applied on rising edge of UPDATE button (always wins)
//
// rPrev_* tracks last applied values so repeated identical
// inputs do not unnecessarily re-trigger motion.
// ============================================================

// MQTT setpoint — only when explicitly enabled and value changed
IF MQTT_Enabled AND (MQTT_Setpoint <> rPrev_MQTT_SP) THEN
    rActiveSetpoint := LIMIT(0.0, MQTT_Setpoint, 100.0);
    rPrev_MQTT_SP   := MQTT_Setpoint;
    Source          := E_ValveSource.MQTT;
END_IF

// HMI Update button overrides MQTT if pressed in the same cycle
IF rtUpdate.Q THEN
    rActiveSetpoint := LIMIT(0.0, HMI_Setpoint, 100.0);
    rPrev_HMI_SP    := HMI_Setpoint;
    Source          := E_ValveSource.HMI;
END_IF

// Convert percentage setpoint to axis units (mm)
rTarget_mm := REAL_TO_LREAL(rActiveSetpoint / 100.0 * FullStroke_mm);


// ============================================================
// SECTION 3 — MC_Power
// Enable drive power. Disable during FAULT to allow safe state.
// Catches unexpected drive errors from any running state.
// ============================================================
fbPower(
    Axis            := Axis,
    Enable          := Enable AND (eState <> E_ValveState.FAULT),
    Enable_Positive := TRUE,    // NC software limits protect max travel
    Enable_Negative := TRUE,    // NC software limits protect min travel
    Override        := 100.0    // 100 % velocity override = full programmed speed
);
bAxisReady := fbPower.Status AND NOT fbPower.Error;

// Trap unexpected drive fault from any non-fault/non-reset state
IF fbPower.Error AND
   eState <> E_ValveState.FAULT AND
   eState <> E_ValveState.RESET AND
   eState <> E_ValveState.INIT
THEN
    FaultCode := fbPower.ErrorID;
    eState    := E_ValveState.FAULT;
END_IF


// ============================================================
// SECTION 4 — MC_ReadActualPosition
// Read current axis position every cycle.
// rActual_mm is then converted to a percentage.
// ============================================================

(*IF TopPosition THEN
	fbSetPos (
		Axis := Axis,
		Execute := TRUE,
		Position := FullStroke_mm
		//Mode
		);	
	IF fbSetPos.Done THEN
		fbSetPos (Execute := FALSE, Axis := Axis);
		rActiveSetpoint := Actual_Position;  // Adopt current position as new setpoint
	END_IF
END_IF *)

fbReadPos(
    Axis   := Axis,
    Enable := fbPower.Status
);
IF fbReadPos.Valid THEN
    rActual_mm := fbReadPos.Position;
END_IF

// Convert mm to percentage of full stroke
IF FullStroke_mm > 0.0 THEN
    Actual_Position := LREAL_TO_REAL(rActual_mm / REAL_TO_LREAL(FullStroke_mm)) * 100.0;
    Actual_Position := LIMIT(0.0, Actual_Position, 100.0);
ELSE
    Actual_Position := 0.0;  // Guard: division by zero if FullStroke_mm not configured
END_IF

// In-position flag: TRUE when within tolerance of active setpoint
InPosition := ABS(Actual_Position - rActiveSetpoint) <= PosTolerance;


// ============================================================
// SECTION 5 — STATE MACHINE
// Each state is responsible for:
//   a) Setting/clearing Execute flags for MC FBs
//   b) Monitoring completion/error conditions
//   c) Transitioning to the next state
// ============================================================
CASE eState OF

    // ----------------------------------------------------------
    // INIT: Clear all Execute flags; wait for drive ready.
    // Drive ready = MC_Power.Status = TRUE, no error.
    // ----------------------------------------------------------
    E_ValveState.INIT:
        bExecHome  := FALSE;
        bExecMove  := FALSE;
        bExecReset := FALSE;
        bExecHalt  := FALSE;

        IF bAxisReady THEN
            eState := E_ValveState.HOMING;
        END_IF

    // ----------------------------------------------------------
    // HOMING: Execute MC_Home to establish zero reference.
    // Position = 0.0 mm means valve fully closed.
    // ZeroPosition (limit switch) is the calibration cam signal.
    // ----------------------------------------------------------
    E_ValveState.HOMING:
        bExecHome := TRUE;

        fbHome(
            Axis            := Axis,
            Execute         := bExecHome,
            Position        := 0.0,             // Home = 0 mm = fully closed
            HomingMode      := eHomingSelection, // MC_Direct sets position without movement
            bCalibrationCam := ZeroPosition      // Wired to limit switch in GVL_IO
        );

        IF fbHome.Done THEN
            bExecHome := FALSE;
            fbHome(Axis := Axis, Execute := bExecHome);  // Clear Execute cleanly
            IsHomed   := TRUE;
			rActiveSetpoint := 0;  // Adopt current position as new setpoint
            eState    := E_ValveState.IDLE;
        ELSIF fbHome.Error THEN
            bExecHome := FALSE;
            fbHome(Axis := Axis, Execute := bExecHome);  // Clear Execute cleanly
            FaultCode := fbHome.ErrorID;
            eState    := E_ValveState.FAULT;
        END_IF

    // ----------------------------------------------------------
    // IDLE: Monitoring for a new setpoint or re-home request.
    // Transition to MOVING only after successful homing.
    // ----------------------------------------------------------
    E_ValveState.IDLE:
        bExecMove := FALSE;

        IF rtHoming.Q THEN
            IsHomed := FALSE;
            eState  := E_ValveState.HOMING;
        END_IF

        IF IsHomed AND ABS(rActiveSetpoint - Actual_Position) > PosTolerance THEN
            bExecMove := TRUE;
            eState    := E_ValveState.MOVING;
        END_IF

    // ----------------------------------------------------------
    // MOVING: Execute MC_MoveAbsolute to reach target position.
    // Transitions:
    //   Done          → HOLD (at position)
    //   CommandAborted→ IDLE (setpoint changed during move)
    //   Error         → FAULT
    //   Move_Stop     → HALT (operator emergency stop)
    // ----------------------------------------------------------
    E_ValveState.MOVING:
        fbMoveAbs(
            Axis         := Axis,
            Execute      := bExecMove,
            Position     := rTarget_mm,
            Velocity     := MoveVelocity,
            Acceleration := MoveAccel,
            Deceleration := MoveDecel,
            Jerk         := MoveJerk,     // 0.0 = trapezoidal; >0 = S-curve
            BufferMode   := MC_BlendingNext,
            Active       => IsMoving,
            Done         => MoveDone
        );

        // Operator STOP button: halt cleanly
        IF Move_Stop THEN
            bExecHalt := TRUE;
            eState    := E_ValveState.HALT;
        END_IF

        IF fbMoveAbs.Done THEN
            bExecMove := FALSE;
            fbMoveAbs(Axis := Axis, Execute := bExecMove);  // Clear Execute cleanly
            eState    := E_ValveState.HOLD;
        ELSIF fbMoveAbs.CommandAborted THEN
            bExecMove := FALSE;
            fbMoveAbs(Axis := Axis, Execute := bExecMove);  // Clear Execute cleanly
            eState    := E_ValveState.IDLE;  // Re-evaluate setpoint on next cycle
        ELSIF fbMoveAbs.Error THEN
            bExecMove := FALSE;
            fbMoveAbs(Axis := Axis, Execute := bExecMove);  // Clear Execute cleanly
            FaultCode := fbMoveAbs.ErrorID;
            eState    := E_ValveState.FAULT;
        END_IF

    // ----------------------------------------------------------
    // HOLD: Valve is at target position.
    // Monitors for new setpoint (→ MOVING) or re-home (→ HOMING).
    // ----------------------------------------------------------
    E_ValveState.HOLD:
        IsMoving  := FALSE;
        bExecMove := FALSE;

        IF ABS(rActiveSetpoint - Actual_Position) > PosTolerance THEN
            bExecMove := TRUE;
            eState    := E_ValveState.MOVING;
        END_IF

        IF rtHoming.Q THEN
            IsHomed := FALSE;
            eState  := E_ValveState.HOMING;
        END_IF

    // ----------------------------------------------------------
    // FAULT: Drive or motion error detected.
    // Latches IsFault = TRUE; waits for Reset command.
    // ──────────────────────────────────────────────────────────
    E_ValveState.FAULT:
        IsFault   := TRUE;
        IsMoving  := FALSE;
        bExecHome := FALSE;
        bExecMove := FALSE;

        IF rtReset.Q THEN
            bExecReset := TRUE;
            eState     := E_ValveState.RESET;
        END_IF

    // ----------------------------------------------------------
    // HALT: MC_Halt stops the axis gracefully.
    // After halt: stay at current position (update setpoint).
    // Reset button returns to IDLE.
    // ----------------------------------------------------------
    E_ValveState.HALT:
        fbHalt(
            Axis         := Axis,
            Execute      := bExecHalt,
            Deceleration := MoveDecel,
            Jerk         := MoveJerk,
            BufferMode   := MC_Aborting
        );

        IF fbHalt.Done THEN
            bExecHalt       := FALSE;
            fbHalt(Axis := Axis, Execute := bExecHalt);  // Clear Execute cleanly
            rActiveSetpoint := Actual_Position;  // Adopt current position as new setpoint
        ELSIF fbHalt.Error THEN
            bExecHalt := FALSE;
            fbHalt(Axis := Axis, Execute := bExecHalt);  // Clear Execute cleanly
            FaultCode := fbHalt.ErrorID;
            eState    := E_ValveState.FAULT;
        END_IF

        IF rtReset.Q THEN
            eState := E_ValveState.IDLE;
        END_IF

    // ----------------------------------------------------------
    // RESET: Clear drive error with MC_Reset, then re-home.
    // IsHomed is cleared because stepper may have lost position.
    // ----------------------------------------------------------
    E_ValveState.RESET:
        fbReset_MC(
            Axis    := Axis,
            Execute := bExecReset
        );

        IF fbReset_MC.Done THEN
            bExecReset := FALSE;
            IsFault    := FALSE;
            FaultCode  := 0;
            IsHomed    := FALSE;  // Must re-home after drive reset
            eState     := E_ValveState.HOMING;
        ELSIF fbReset_MC.Error THEN
            bExecReset := FALSE;  // Next Reset press will retry
            FaultCode  := fbReset_MC.ErrorID;
            // Stay in RESET
        END_IF

ELSE
    // Unknown state — safety fallback: restart from INIT
    eState := E_ValveState.INIT;

END_CASE


// ============================================================
// SECTION 6 — OUTPUT ASSIGNMENT
// Mirror internal state to VAR_OUTPUT for MAIN and HMI.
// ============================================================
State   := eState;
IsFault := (eState = E_ValveState.FAULT);
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>