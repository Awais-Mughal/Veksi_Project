<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_SensorIO" Id="{d1e2f3a4-b5c6-7890-abcd-ef0123456789}" SpecialFunc="None">
    <Declaration><![CDATA[(*
============================================================
FUNCTION_BLOCK: FB_SensorIO
============================================================

PURPOSE
  Reads raw analog INT values from GVL_IO (EL3074 / EL3202),
  scales them to engineering units, applies a low-pass filter
  for noise rejection, detects sensor faults, and outputs
  a fully populated ST_SensorData struct.

  Call this block once per PLC cycle in MAIN before any
  other FB that consumes sensor data.

INPUTS
  bEnable         — Master enable; when FALSE outputs hold
                    last valid value and bAnySensorFault = TRUE.
  rLpfAlpha       — Low-pass filter coefficient (0.0–1.0).
                    0.0 = no filtering (pass-through).
                    0.9 = heavy filtering (slow to respond).
                    Default 0.1 gives moderate noise rejection.

OUTPUTS
  stOut           — Fully populated ST_SensorData struct.

WATER LEVEL SCALING
  Linear mapping: (raw − RAW_MIN) / (RAW_MAX − RAW_MIN) × ENG_RANGE
  Scaling constants defined in GVL_Config.

TEMPERATURE SCALING
  EL3202 RTD card outputs tenths of a degree Celsius as INT.
  e.g. raw = 250 → 250 × 0.1 + OFFSET = 25.0 °C

FAULT DETECTION
  Any raw value ≤ GVL_Config.SENSOR_FAULT_THRESHOLD is treated
  as a disconnected or failed sensor (default threshold = -100;
  unconnected GVL_IO stubs initialize to -999).

HARDWARE MAPPING (GVL_IO)
  Water level:   AI_L1V11 (primary), AI_L1V20, AI_L2V21
  Temperature:   AI_Tmp_1, AI_Tmp_2  (EL3202 PT100)
  Position FB:   AI_PosFeedback_1/2/3 (supplementary only)

LIBRARIES
  Tc2_Standard
============================================================
*)

FUNCTION_BLOCK FB_SensorIO
VAR_INPUT
    bEnable     : BOOL := TRUE;     (* Master enable; FALSE holds last value *)
    rLpfAlpha   : REAL := 0.1;      (* Low-pass filter: 0.0=off, 0.9=heavy   *)
END_VAR

VAR_OUTPUT
    stOut       : ST_SensorData;    (* All sensor readings in engineering units *)
END_VAR

VAR
    (* ── Low-pass filter state variables ─────────────────────── *)
    rFilt_WaterLevel    : REAL;
    rFilt_Temp1         : REAL;
    rFilt_Temp2         : REAL;
    rFilt_PosFb         : ARRAY[1..3] OF REAL;

    (* ── Scaled (pre-filter) intermediate values ──────────────── *)
    rRaw_WaterLevel_mm  : REAL;
    rRaw_Temp1_C        : REAL;
    rRaw_Temp2_C        : REAL;
    rRaw_PosFb_mm       : ARRAY[1..3] OF REAL;

    (* ── First-scan flag (initialise filters from first reading) *)
    bFirstScan          : BOOL := TRUE;

    i                   : INT;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[// ============================================================
// SECTION 1 — ENABLE GUARD
// ============================================================
IF NOT bEnable THEN
    stOut.bAnySensorFault := TRUE;
    stOut.bWaterLevelFault := TRUE;
    stOut.bTempFault[1]   := TRUE;
    stOut.bTempFault[2]   := TRUE;
    RETURN;
END_IF


// ============================================================
// SECTION 2 — FAULT DETECTION
// A raw value ≤ SENSOR_FAULT_THRESHOLD indicates disconnection.
// ============================================================

stOut.bWaterLevelFault  := GVL_IO.AI_L1V11 <= GVL_Config.SENSOR_FAULT_THRESHOLD;
stOut.bTempFault[1]     := GVL_IO.AI_Tmp_1 <= GVL_Config.SENSOR_FAULT_THRESHOLD;
stOut.bTempFault[2]     := GVL_IO.AI_Tmp_2 <= GVL_Config.SENSOR_FAULT_THRESHOLD;

FOR i := 1 TO 3 DO
    CASE i OF
        1: stOut.bPosFeedbackFault[i] := GVL_IO.AI_PosFeedback_1 <= GVL_Config.SENSOR_FAULT_THRESHOLD;
        2: stOut.bPosFeedbackFault[i] := GVL_IO.AI_PosFeedback_2 <= GVL_Config.SENSOR_FAULT_THRESHOLD;
        3: stOut.bPosFeedbackFault[i] := GVL_IO.AI_PosFeedback_3 <= GVL_Config.SENSOR_FAULT_THRESHOLD;
    END_CASE
END_FOR

stOut.bAnySensorFault :=
    stOut.bWaterLevelFault OR
    stOut.bTempFault[1]    OR
    stOut.bTempFault[2];


// ============================================================
// SECTION 3 — RAW VALUE CAPTURE
// Store raw counts for diagnostics and fault logging.
// ============================================================

stOut.rWaterLevel_raw   := GVL_IO.AI_L1V11;
stOut.rTemperature_raw[1] := GVL_IO.AI_Tmp_1;
stOut.rTemperature_raw[2] := GVL_IO.AI_Tmp_2;
stOut.rPosFeedback_raw[1] := GVL_IO.AI_PosFeedback_1;
stOut.rPosFeedback_raw[2] := GVL_IO.AI_PosFeedback_2;
stOut.rPosFeedback_raw[3] := GVL_IO.AI_PosFeedback_3;


// ============================================================
// SECTION 4 — SCALING TO ENGINEERING UNITS
// Only scale valid readings; keep last valid value on fault.
// ============================================================

IF NOT stOut.bWaterLevelFault THEN
    // Linear: mm = (raw - rawMin) / (rawMax - rawMin) * engRange + engMin
    rRaw_WaterLevel_mm := ScaleLinear(
        INT_TO_REAL(GVL_IO.AI_L1V11),
        INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MIN),
        INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MAX),
        GVL_Config.WATER_LEVEL_ENG_MIN_MM,
        GVL_Config.WATER_LEVEL_ENG_MAX_MM);
    rRaw_WaterLevel_mm := LIMIT(GVL_Config.WATER_LEVEL_ENG_MIN_MM, rRaw_WaterLevel_mm, GVL_Config.WATER_LEVEL_ENG_MAX_MM);
END_IF

IF NOT stOut.bTempFault[1] THEN
    // EL3202 outputs tenths of a degree: divide by 10 (or apply scale factor)
    rRaw_Temp1_C := INT_TO_REAL(GVL_IO.AI_Tmp_1) * GVL_Config.TEMP_RAW_SCALE_FACTOR + GVL_Config.TEMP_OFFSET_C;
END_IF

IF NOT stOut.bTempFault[2] THEN
    rRaw_Temp2_C := INT_TO_REAL(GVL_IO.AI_Tmp_2) * GVL_Config.TEMP_RAW_SCALE_FACTOR + GVL_Config.TEMP_OFFSET_C;
END_IF

FOR i := 1 TO 3 DO
    IF NOT stOut.bPosFeedbackFault[i] THEN
        CASE i OF
            1: rRaw_PosFb_mm[i] := ScaleLinear(
                    INT_TO_REAL(GVL_IO.AI_PosFeedback_1),
                    INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MIN),
                    INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MAX),
                    GVL_Config.WATER_LEVEL_ENG_MIN_MM,
                    GVL_Config.VALVE_FULL_STROKE_MM);
            2: rRaw_PosFb_mm[i] := ScaleLinear(
                    INT_TO_REAL(GVL_IO.AI_PosFeedback_2),
                    INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MIN),
                    INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MAX),
                    GVL_Config.WATER_LEVEL_ENG_MIN_MM,
                    GVL_Config.VALVE_FULL_STROKE_MM);
            3: rRaw_PosFb_mm[i] := ScaleLinear(
                    INT_TO_REAL(GVL_IO.AI_PosFeedback_3),
                    INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MIN),
                    INT_TO_REAL(GVL_Config.WATER_LEVEL_RAW_MAX),
                    GVL_Config.WATER_LEVEL_ENG_MIN_MM,
                    GVL_Config.VALVE_FULL_STROKE_MM);
        END_CASE
    END_IF
END_FOR


// ============================================================
// SECTION 5 — LOW-PASS FILTER
// y[n] = alpha * x[n] + (1 - alpha) * y[n-1]
// On first scan, seed the filter with the current reading so
// there is no transient from 0 to actual value.
// ============================================================

IF bFirstScan THEN
    rFilt_WaterLevel := rRaw_WaterLevel_mm;
    rFilt_Temp1      := rRaw_Temp1_C;
    rFilt_Temp2      := rRaw_Temp2_C;
    FOR i := 1 TO 3 DO
        rFilt_PosFb[i] := rRaw_PosFb_mm[i];
    END_FOR
    bFirstScan := FALSE;
ELSE
    rFilt_WaterLevel := rLpfAlpha * rRaw_WaterLevel_mm + (1.0 - rLpfAlpha) * rFilt_WaterLevel;
    rFilt_Temp1      := rLpfAlpha * rRaw_Temp1_C      + (1.0 - rLpfAlpha) * rFilt_Temp1;
    rFilt_Temp2      := rLpfAlpha * rRaw_Temp2_C      + (1.0 - rLpfAlpha) * rFilt_Temp2;
    FOR i := 1 TO 3 DO
        rFilt_PosFb[i] := rLpfAlpha * rRaw_PosFb_mm[i] + (1.0 - rLpfAlpha) * rFilt_PosFb[i];
    END_FOR
END_IF


// ============================================================
// SECTION 6 — WRITE OUTPUTS
// ============================================================

stOut.rWaterLevel_mm   := rFilt_WaterLevel;

// Water level percent: 0–100 based on engineering range
IF GVL_Config.WATER_LEVEL_ENG_MAX_MM > GVL_Config.WATER_LEVEL_ENG_MIN_MM THEN
    stOut.rWaterLevel_pct := LIMIT(0.0,
        (rFilt_WaterLevel - GVL_Config.WATER_LEVEL_ENG_MIN_MM) /
        (GVL_Config.WATER_LEVEL_ENG_MAX_MM - GVL_Config.WATER_LEVEL_ENG_MIN_MM) * 100.0,
        100.0);
ELSE
    stOut.rWaterLevel_pct := 0.0;
END_IF

stOut.rTemperature_C[1] := rFilt_Temp1;
stOut.rTemperature_C[2] := rFilt_Temp2;

FOR i := 1 TO 3 DO
    stOut.rPosFeedback_mm[i] := rFilt_PosFb[i];
END_FOR
]]></ST>
    </Implementation>
    <Method Name="ScaleLinear" Id="{a1b2c3d4-e5f6-7890-abcd-ef0123456789}">
      <Declaration><![CDATA[(*
============================================================
METHOD: ScaleLinear
============================================================
PURPOSE
  Maps a raw value from [rawMin, rawMax] to [engMin, engMax]
  using linear interpolation.

  result = engMin + (raw - rawMin) / (rawMax - rawMin) * (engMax - engMin)

  If rawMax = rawMin the method returns engMin to avoid
  division by zero.
============================================================
*)
METHOD ScaleLinear : REAL
VAR_INPUT
    rRaw    : REAL;
    rRawMin : REAL;
    rRawMax : REAL;
    rEngMin : REAL;
    rEngMax : REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF rRawMax = rRawMin THEN
    ScaleLinear := rEngMin;
    RETURN;
END_IF

ScaleLinear := rEngMin + (rRaw - rRawMin) / (rRawMax - rRawMin) * (rEngMax - rEngMin);
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
