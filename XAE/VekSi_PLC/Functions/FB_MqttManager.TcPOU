<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_MqttManager" Id="{a85faad5-c4ce-456e-ac7f-31861d0adeef}" SpecialFunc="None">
    <Declaration><![CDATA[(*
============================================================
FUNCTION_BLOCK: FB_MqttManager
============================================================

PURPOSE
  Central MQTT manager for the irrigation system.
  Handles connection lifecycle, topic subscription, cyclic
  status publishing, and incoming JSON command parsing.

CONNECTION STATE MACHINE
  DISABLED     — bEnable = FALSE; waiting to be enabled
  CONNECTING   — Applying config and requesting connection
  CONNECTED    — Active; monitoring for loss or config change
  DISCONNECTING— Gracefully closing connection
  WAIT_RECONNECT— Back-off delay before retry

OUTGOING JSON (published to stConfig.sMainTopic):
  {
    "timestamp": "2026-04-28 12:00:00",
    "valve_1_setpoint": 50.0, "valve_1_actual": 49.8, "valve_1_source": "HMI",
    "valve_2_setpoint": 25.0, "valve_2_actual": 25.1, "valve_2_source": "MQTT",
    "valve_3_setpoint": 75.0, "valve_3_actual": 74.9, "valve_3_source": "HMI",
    "temperature_c": 22.5,
    "water_level_pct": 65.3,
    "water_level_mm": 653.0
  }

INCOMING JSON (subscribed from stConfig.SubscribeTopic):
  {
    "Valve1": 50, "Valve2": 25, "Valve3": 75,
    "Valve1_Enable": true, "Valve2_Enable": true, "Valve3_Enable": false
  }
  Setpoints are in % (0-100). ValveN_Enable gates MQTT override.
  Deserialized into ST_MQTT_Command via Beckhoff JSON parser.

AUTO-SUBSCRIBE
  On every new connection (CONNECTED state), the FB automatically
  subscribes to stConfig.SubscribeTopic. No external trigger needed.

LIBRARIES
  TF6701 / Tc3_IotBase, Tc3_JsonXml, Tc2_Standard
============================================================
*)

FUNCTION_BLOCK FB_MqttManager
VAR_INPUT
    (* Connection control *)
    bEnable             : BOOL;             (* Master enable; FALSE disconnects MQTT     *)
    stConfig            : ST_MqttConfig;    (* Broker address, port, username, topics    *)
    bApplyConfig        : BOOL;             (* Rising edge: reconnect with new config    *)

    (* Manual publish *)
    bPublish            : BOOL;             (* Rising edge: publish current status JSON  *)

    (* Cyclic status publishing *)
    bEnableStatusPublish : BOOL;            (* TRUE = publish status JSON cyclically     *)
    tStatusPublishTime   : TIME;            (* Interval, e.g. T#5M                       *)
    sStatusTopic         : STRING(255);     (* Publish topic, e.g. 'irrigation/status'  *)

    (* System data for outgoing JSON *)
    rValveSetpoint      : ARRAY[1..3] OF REAL;      (* Active setpoints 0-100 %          *)
    rValveActual        : ARRAY[1..3] OF REAL;      (* Actual positions 0-100 %          *)
    sValveSource        : ARRAY[1..3] OF STRING(8); (* 'HMI', 'MQTT', or 'NONE'          *)
    rTemperature_C      : REAL;             (* Temperature probe 1 in degrees C          *)
    rWaterLevel_pct     : REAL;             (* Water level 0-100 %                      *)
    rWaterLevel_mm      : REAL;             (* Water level in mm                        *)
    sTimestamp          : STRING(64);       (* Current time as 'YYYY-MM-DD HH:MM:SS'    *)
END_VAR

VAR_OUTPUT
    (* Connection status *)
    bConnected          : BOOL;             (* TRUE when broker is connected             *)
    bError              : BOOL;             (* TRUE on error or during reconnect wait    *)
    nErrorCode          : HRESULT;          (* MQTT HRESULT error code (0 = OK)          *)
    sErrorMsg           : STRING(128);      (* Human-readable error description          *)

    (* Incoming command outputs *)
    bNewRemoteCommand       : BOOL;                     (* TRUE for one cycle on valid command  *)
    rMqttValveSetpoint      : ARRAY[1..3] OF REAL;      (* Parsed setpoints 0-100 %             *)
    bMqttValveEnable        : ARRAY[1..3] OF BOOL;      (* Per-valve MQTT override enable        *)

    (* Last received message for diagnostics *)
    sLastRxTopic        : STRING(255);      (* Last received topic                       *)
    sLastRxPayload      : STRING(2048);     (* Last received payload                     *)

    (* Outgoing JSON preview for HMI / debugging *)
    sJsonStatusPayload  : STRING(2048);
END_VAR

VAR
    (* MQTT client and message queue *)
    fbMqttClient    : FB_IotMqttClient;
    fbMessageQueue  : FB_IotMqttMessageQueue;
    fbMessage       : FB_IotMqttMessage;

    (* Connection state machine *)
    eState : (
        DISABLED,
        CONNECTING,
        CONNECTED,
        DISCONNECTING,
        WAIT_RECONNECT
    );

    (* Edge detection *)
    rtApplyConfig   : R_TRIG;
    rtPublish       : R_TRIG;

    (* Timers *)
    tonReconnect        : TON;
    tonStatusPublish    : TON;

    (* Internal flags *)
    bConnectCmd                 : BOOL;
    bReconnectAfterDisconnect   : BOOL;
    bAutoSubscribed             : BOOL;     (* TRUE after subscribe on this connection *)

    (* JSON processing *)
    fbJson          : FB_JsonDomParser;
    fbJsonDataType  : FB_JsonReadWriteDatatype;
    stCmdRecv       : ST_MQTT_Command;
    bSuccess        : BOOL;

    sTopicRcv       : STRING(255);
    sPayloadRcv     : STRING(2048);
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ============================================================
   EDGE DETECTION
   ============================================================ *)
rtApplyConfig(CLK := bApplyConfig);
rtPublish(CLK := bPublish);


(* ============================================================
   RESET ONE-CYCLE FEEDBACK FLAGS
   ============================================================ *)
bNewRemoteCommand := FALSE;


(* ============================================================
   CONNECTION STATE MACHINE
   ============================================================ *)
CASE eState OF

    (* -----------------------------------------------------------
       DISABLED — MQTT off, waiting for operator enable
       ----------------------------------------------------------- *)
    DISABLED:
        bConnectCmd               := FALSE;
        bAutoSubscribed           := FALSE;
        sErrorMsg                 := '';
        bReconnectAfterDisconnect := FALSE;

        IF bEnable THEN
            eState := CONNECTING;
        END_IF


    (* -----------------------------------------------------------
       CONNECTING — apply config and request connection
       Config must be assigned before Execute(TRUE) is called.
       ----------------------------------------------------------- *)
    CONNECTING:
        fbMqttClient.sHostName      := stConfig.sBrokerAddress;
        fbMqttClient.nHostPort      := stConfig.nPort;
        fbMqttClient.sClientId      := stConfig.sClientId;
        fbMqttClient.sUserName      := stConfig.sUsername;
        fbMqttClient.sUserPassword  := stConfig.sPassword;
        fbMqttClient.ipMessageQueue := fbMessageQueue;

        bConnectCmd := TRUE;

        IF fbMqttClient.bConnected THEN
            sErrorMsg       := '';
            bAutoSubscribed := FALSE;   (* Will subscribe on first CONNECTED cycle *)
            eState          := CONNECTED;
        ELSIF fbMqttClient.bError THEN
            sErrorMsg := 'MQTT connect failed - check broker IP, port, credentials.';
            eState    := WAIT_RECONNECT;
        END_IF


    (* -----------------------------------------------------------
       CONNECTED — connection active.
       Auto-subscribe on first entry.
       Monitor for config change, enable toggle, or dropout.
       ----------------------------------------------------------- *)
    CONNECTED:
        bConnectCmd := TRUE;

        (* Auto-subscribe to command topic once per connection.
           Subscribe returns TRUE when the request is accepted. *)
        IF NOT bAutoSubscribed THEN
            bAutoSubscribed := fbMqttClient.Subscribe(
                sTopic := stConfig.SubscribeTopic,
                eQoS   := TcIotMqttQos.AtLeastOnceDelivery);
        END_IF

        IF NOT bEnable THEN
            bReconnectAfterDisconnect := FALSE;
            eState := DISCONNECTING;
        ELSIF rtApplyConfig.Q THEN
            (* Config changed: disconnect then reconnect with new settings *)
            bReconnectAfterDisconnect := TRUE;
            bAutoSubscribed           := FALSE;
            eState                    := DISCONNECTING;
        ELSIF NOT fbMqttClient.bConnected THEN
            sErrorMsg := 'MQTT connection lost - reconnecting...';
            eState    := WAIT_RECONNECT;
        END_IF


    (* -----------------------------------------------------------
       DISCONNECTING — Execute(FALSE) closes the connection.
       ----------------------------------------------------------- *)
    DISCONNECTING:
        bConnectCmd := FALSE;

        IF NOT fbMqttClient.bConnected THEN
            IF bEnable AND bReconnectAfterDisconnect THEN
                bReconnectAfterDisconnect := FALSE;
                eState := CONNECTING;
            ELSE
                eState := DISABLED;
            END_IF
        END_IF


    (* -----------------------------------------------------------
       WAIT_RECONNECT — back-off delay before next attempt.
       ----------------------------------------------------------- *)
    WAIT_RECONNECT:
        bConnectCmd := FALSE;
        tonReconnect(IN := TRUE, PT := stConfig.tReconnectDelay);

        IF NOT bEnable THEN
            tonReconnect(IN := FALSE);
            eState := DISABLED;
        ELSIF tonReconnect.Q THEN
            tonReconnect(IN := FALSE);
            eState := CONNECTING;
        END_IF

END_CASE


(* ============================================================
   EXECUTE MQTT CLIENT
   Must be called every PLC cycle.
   TRUE = connect/maintain connection; FALSE = disconnect.
   ============================================================ *)
fbMqttClient.Execute(bConnectCmd);


(* ============================================================
   INCOMING MESSAGE PROCESSING
   Drain all queued messages; parse JSON into ST_MQTT_Command.

   INDEX CORRECTION (original had Valve2/Valve3 swapped):
     stCmdRecv.Valve1 -> rMqttValveSetpoint[1]
     stCmdRecv.Valve2 -> rMqttValveSetpoint[2]
     stCmdRecv.Valve3 -> rMqttValveSetpoint[3]
   ============================================================ *)
WHILE fbMessageQueue.nQueuedMessages > 0 DO
    IF fbMessageQueue.Dequeue(fbMessage := fbMessage) THEN
        fbMessage.GetTopic(
            pTopic      := ADR(sTopicRcv),
            nTopicSize  := SIZEOF(sTopicRcv));
        fbMessage.GetPayload(
            pPayload            := ADR(sPayloadRcv),
            nPayloadSize        := SIZEOF(sPayloadRcv),
            bSetNullTermination := TRUE);

        sLastRxTopic   := sTopicRcv;
        sLastRxPayload := sPayloadRcv;

        (* Attempt JSON deserialization into ST_MQTT_Command struct *)
        bSuccess := fbJsonDataType.SetSymbolFromJson(
            sPayloadRcv, 'ST_MQTT_COMMAND', SIZEOF(stCmdRecv), ADR(stCmdRecv));

        IF bSuccess THEN
            bNewRemoteCommand := TRUE;

            (* Clamp to valid range 0-100 % *)
            rMqttValveSetpoint[1] := LIMIT(0.0, DINT_TO_REAL(stCmdRecv.Valve1), 100.0);
            rMqttValveSetpoint[2] := LIMIT(0.0, DINT_TO_REAL(stCmdRecv.Valve2), 100.0);
            rMqttValveSetpoint[3] := LIMIT(0.0, DINT_TO_REAL(stCmdRecv.Valve3), 100.0);

            (* Per-valve MQTT override enable *)
            bMqttValveEnable[1] := stCmdRecv.Valve1_Enable;
            bMqttValveEnable[2] := stCmdRecv.Valve2_Enable;
            bMqttValveEnable[3] := stCmdRecv.Valve3_Enable;
        END_IF
    END_IF
END_WHILE


(* ============================================================
   MANUAL PUBLISH
   Triggered by rising edge on bPublish.
   Builds and immediately publishes the current status JSON.
   ============================================================ *)
IF fbMqttClient.bConnected AND rtPublish.Q THEN
    BuildStatusJson();
    fbMqttClient.Publish(
        sTopic       := stConfig.sMainTopic,
        pPayload     := ADR(sJsonStatusPayload),
        nPayloadSize := LEN(sJsonStatusPayload),
        eQoS         := TcIotMqttQos.AtMostOnceDelivery,
        bRetain      := TRUE    (* Retained so new subscribers get current state *)
    );
END_IF


(* ============================================================
   CYCLIC STATUS PUBLISH
   Publishes every tStatusPublishTime. Timer resets immediately
   on expiry to create a repeating cycle.
   ============================================================ *)
tonStatusPublish(
    IN := bEnableStatusPublish AND fbMqttClient.bConnected,
    PT := tStatusPublishTime
);

IF tonStatusPublish.Q THEN
    tonStatusPublish(IN := FALSE);      (* Reset for next cycle *)
    BuildStatusJson();
    fbMqttClient.Publish(
        sTopic       := sStatusTopic,
        pPayload     := ADR(sJsonStatusPayload),
        nPayloadSize := LEN(sJsonStatusPayload),
        eQoS         := TcIotMqttQos.AtMostOnceDelivery,
        bRetain      := FALSE
    );
END_IF


(* ============================================================
   OUTPUT STATUS
   ============================================================ *)
bConnected := fbMqttClient.bConnected;
nErrorCode := fbMqttClient.hrErrorCode;
bError     := fbMqttClient.bError OR (eState = WAIT_RECONNECT);

IF NOT bError THEN
    nErrorCode := 0;
END_IF
]]></ST>
    </Implementation>
    <Method Name="BuildStatusJson" Id="{bc75ef4b-b89a-47f3-acd6-d73e4c45bc14}">
      <Declaration><![CDATA[(*
============================================================
METHOD: BuildStatusJson
============================================================
PURPOSE
  Assembles the outgoing JSON status payload from current
  system data stored in VAR_INPUT. Writes result into
  sJsonStatusPayload (VAR_OUTPUT).

OUTPUT FORMAT EXAMPLE
  {"timestamp":"2026-04-28 12:00:00",
   "valve_1_setpoint":50.0,"valve_1_actual":49.8,"valve_1_source":"HMI",
   "valve_2_setpoint":25.0,"valve_2_actual":25.1,"valve_2_source":"MQTT",
   "valve_3_setpoint":75.0,"valve_3_actual":74.9,"valve_3_source":"HMI",
   "temperature_c":22.5,"water_level_pct":65.3,"water_level_mm":653.0}
============================================================
*)
METHOD BuildStatusJson
VAR
    sTemp : STRING(2048);
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[sTemp := '{';

sTemp := CONCAT(sTemp, '"timestamp":"');
sTemp := CONCAT(sTemp, sTimestamp);
sTemp := CONCAT(sTemp, '"');

sTemp := CONCAT(sTemp, ',"valve_1_setpoint":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rValveSetpoint[1]));
sTemp := CONCAT(sTemp, ',"valve_1_actual":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rValveActual[1]));
sTemp := CONCAT(sTemp, ',"valve_1_source":"');
sTemp := CONCAT(sTemp, sValveSource[1]);
sTemp := CONCAT(sTemp, '"');

sTemp := CONCAT(sTemp, ',"valve_2_setpoint":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rValveSetpoint[2]));
sTemp := CONCAT(sTemp, ',"valve_2_actual":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rValveActual[2]));
sTemp := CONCAT(sTemp, ',"valve_2_source":"');
sTemp := CONCAT(sTemp, sValveSource[2]);
sTemp := CONCAT(sTemp, '"');

sTemp := CONCAT(sTemp, ',"valve_3_setpoint":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rValveSetpoint[3]));
sTemp := CONCAT(sTemp, ',"valve_3_actual":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rValveActual[3]));
sTemp := CONCAT(sTemp, ',"valve_3_source":"');
sTemp := CONCAT(sTemp, sValveSource[3]);
sTemp := CONCAT(sTemp, '"');

sTemp := CONCAT(sTemp, ',"temperature_c":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rTemperature_C));

sTemp := CONCAT(sTemp, ',"water_level_pct":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rWaterLevel_pct));

sTemp := CONCAT(sTemp, ',"water_level_mm":');
sTemp := CONCAT(sTemp, REAL_TO_STRING(rWaterLevel_mm));

sTemp := CONCAT(sTemp, '}');

sJsonStatusPayload := sTemp;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetClientRef" Id="{5df7620b-3e01-4e9d-936d-deef8a5db0c8}">
      <Declaration><![CDATA[(*
============================================================
METHOD: GetClientRef
============================================================
PURPOSE
  Returns a reference to the internal FB_IotMqttClient.
  Use only when you need access to advanced client features
  not exposed via this FB's standard inputs/outputs.
============================================================
*)
METHOD GetClientRef : REFERENCE TO FB_IotMqttClient
]]></Declaration>
      <Implementation>
        <ST><![CDATA[GetClientRef REF= fbMqttClient;
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>
