<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="FB_CsvLogger" Id="{8a84e9fd-9a8f-453a-90ca-561ec719d60c}" SpecialFunc="None">
    <Declaration><![CDATA[(*
============================================================
FUNCTION_BLOCK: FB_CsvLogger
============================================================

PURPOSE
  Appends one CSV row per log interval to a monthly log file
  on the IPC local filesystem (C:\TwinCAT\3.1\Boot\Log\).

FILE NAMING
  <sBasePath><sPrefix><YYYY-MM>.csv
  Example: C:\TwinCAT\3.1\Boot\Log\IrrigationLog_2026-04.csv

CSV COLUMNS
  Timestamp, V1_Setpoint_%, V1_Actual_%, V1_Source, V1_State,
  V2_Setpoint_%, V2_Actual_%, V2_Source, V2_State,
  V3_Setpoint_%, V3_Actual_%, V3_Source, V3_State,
  WaterLevel_mm, WaterLevel_%, Temperature1_C, Temperature2_C

STATE MACHINE
  CSV_IDLE       — Waiting for trigger (timer or force write)
  CSV_PREPARE    — Build filename, check if file exists
  CSV_OPEN       — Open file in append mode
  CSV_WRITE_HDR  — Write column header (new file only)
  CSV_WRITE_ROW  — Append one data row
  CSV_CLOSE      — Close file handle
  CSV_ERROR      — I/O error; waits for next trigger to retry

NOTES
  - File I/O FBs are non-blocking; each step may span PLC cycles.
  - bForceWrite forces a row write outside the normal interval.
  - Header is written only on the first write to a new file.

LIBRARIES
  Tc2_Utilities (FB_FileOpen, FB_FileWrite, FB_FileClose, FB_EnumFindFileEntry)
  Tc2_System    (FB_LocalSystemTime)
============================================================
*)

FUNCTION_BLOCK FB_CsvLogger

VAR_INPUT
    bEnable         : BOOL := TRUE;         (* Master enable; FALSE skips all logging    *)
    bForceWrite     : BOOL;                 (* Rising edge: write a row immediately      *)
    tLogInterval    : TIME;                 (* Periodic write interval (e.g. T#15M)      *)
    sBasePath       : STRING(128);          (* Folder path including trailing backslash  *)
    sPrefix         : T_MaxString;          (* Filename prefix (e.g. 'IrrigationLog_')   *)
    stValve         : ARRAY[1..3] OF ST_ValveData;  (* Valve runtime data from GVL_System *)
    stSensors       : ST_SensorData;        (* Sensor readings from FB_SensorIO          *)
END_VAR

VAR_OUTPUT
    bBusy           : BOOL;                 (* TRUE while file I/O is in progress        *)
    bError          : BOOL;                 (* TRUE on file I/O error                    *)
    nErrorCode      : UDINT;               (* Error code from file FB (0 = OK)           *)
    dtLastWrite     : DT;                   (* Timestamp of last successful row write     *)
    sCurrentFilename : STRING(128);         (* Active filename (without path)             *)
    sCurrentFile    : STRING(128);          (* Full file path currently being written     *)
    eState          : E_CSVLogState := E_CSVLogState.CSV_IDLE;
END_VAR

VAR
    (* File I/O FBs *)
    fbFileOpen      : FB_FileOpen;
    fbFileWrite     : FB_FileWrite;
    fbFileClose     : FB_FileClose;
    hFilenumber     : UINT;
    cbLen           : UDINT;

    (* Timing *)
    tIntervalTimer  : TON;
    bForceEdge      : R_TRIG;
    bTriggerWrite   : BOOL;

    (* Date/time *)
    fbGetTime       : FB_LocalSystemTime;
    sTimestamp      : STRING(24);   (* YYYY-MM-DD HH:MM:SS *)
    nYear           : UINT;
    nMonth          : UINT;
    sYear           : STRING(8);
    sMonth          : STRING(4);

    (* File existence check *)
    fbEnum          : FB_EnumFindFileEntry;
    bEnumStart      : BOOL;
    bFileExists     : BOOL;

    (* String building *)
    sLine           : STRING(512);
    sHeader         : STRING(512);
    sSource         : STRING(8);    (* Temp variable for source text per valve *)
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[(* ============================================================
   GET CURRENT TIME every PLC cycle.
   fbGetTime.systemTime holds year, month, day, hour, min, sec.
   ============================================================ *)
fbGetTime(bEnable := TRUE, dwCycle := 1);


(* ============================================================
   ENABLE GUARD
   When disabled, reset timers but stay in IDLE.
   ============================================================ *)
IF NOT bEnable THEN
    tIntervalTimer(IN := FALSE);
    eState := E_CSVLogState.CSV_IDLE;
    RETURN;
END_IF


(* ============================================================
   TRIGGER LOGIC
   bTriggerWrite fires on:
     a) interval timer expiry (tLogInterval)
     b) rising edge on bForceWrite (manual button)
   ============================================================ *)
bForceEdge(CLK := bForceWrite);
tIntervalTimer(IN := TRUE, PT := tLogInterval);
bTriggerWrite := tIntervalTimer.Q OR bForceEdge.Q;

IF tIntervalTimer.Q THEN
    tIntervalTimer(IN := FALSE);   (* Reset timer for next interval *)
END_IF


(* ============================================================
   STATE MACHINE
   ============================================================ *)
CASE eState OF

    (* ----------------------------------------------------------
       CSV_IDLE — waiting for write trigger
       ---------------------------------------------------------- *)
    E_CSVLogState.CSV_IDLE:
        bBusy := FALSE;

        IF bTriggerWrite THEN
            bFileExists := FALSE;
            bEnumStart  := TRUE;
            eState      := E_CSVLogState.CSV_PREPARE;
        END_IF

    (* ----------------------------------------------------------
       CSV_PREPARE — build filename, check if file already exists.
       Monthly rotation: IrrigationLog_YYYY-MM.csv
       ---------------------------------------------------------- *)
    E_CSVLogState.CSV_PREPARE:
        bBusy := TRUE;

        nYear  := fbGetTime.systemTime.wYear;
        nMonth := fbGetTime.systemTime.wMonth;
        sYear  := UINT_TO_STRING(nYear);
        sMonth := UINT_TO_STRING(nMonth);

        IF nMonth < 10 THEN
            sMonth := CONCAT('0', sMonth);   (* Zero-pad single-digit month *)
        END_IF

        sCurrentFilename := CONCAT(sPrefix, sYear);
        sCurrentFilename := CONCAT(sCurrentFilename, '-');
        sCurrentFilename := CONCAT(sCurrentFilename, sMonth);
        sCurrentFilename := CONCAT(sCurrentFilename, '.csv');
        sCurrentFile     := CONCAT(sBasePath, sCurrentFilename);

        (* Use FB_EnumFindFileEntry to check if file already exists.
           If it does, we skip the header row. *)
        IF bEnumStart THEN
            fbEnum(
                sPathName := sCurrentFile,
                eCmd      := eEnumCmd_First,
                bExecute  := TRUE,
                tTimeout  := T#5S);
            bEnumStart := FALSE;
        ELSE
            fbEnum(
                sPathName := sCurrentFile,
                eCmd      := eEnumCmd_Next,
                bExecute  := FALSE,
                tTimeout  := T#5S);
        END_IF

        IF NOT fbEnum.bBusy THEN
            fbEnum(bExecute := FALSE);
            IF fbEnum.bError THEN
                bFileExists := FALSE;   (* Error means file not found = new file *)
            ELSE
                bFileExists := (fbEnum.stFindFile.sFileName <> '');
            END_IF
            eState := E_CSVLogState.CSV_OPEN;
        END_IF

    (* ----------------------------------------------------------
       CSV_OPEN — open file in append mode (creates if not exists)
       ---------------------------------------------------------- *)
    E_CSVLogState.CSV_OPEN:
        fbFileOpen(
            sPathName := sCurrentFile,
            nMode     := FOPEN_MODEAPPEND,
            bExecute  := TRUE,
            hFile     => hFilenumber);

        IF NOT fbFileOpen.bBusy THEN
            fbFileOpen(bExecute := FALSE);
            IF NOT fbFileOpen.bError THEN
                hFilenumber := fbFileOpen.hFile;
                IF NOT bFileExists THEN
                    eState := E_CSVLogState.CSV_WRITE_HDR;   (* New file: write header first *)
                ELSE
                    eState := E_CSVLogState.CSV_WRITE_ROW;   (* Existing file: append row    *)
                END_IF
            ELSE
                nErrorCode := fbFileOpen.nErrId;
                bError     := TRUE;
                eState     := E_CSVLogState.CSV_ERROR;
            END_IF
        END_IF

    (* ----------------------------------------------------------
       CSV_WRITE_HDR — write column header row for new files.
       Columns: Timestamp, valve data (×3), sensors.
       ---------------------------------------------------------- *)
    E_CSVLogState.CSV_WRITE_HDR:
        sHeader := 'Timestamp,V1_Setpoint_%,V1_Actual_%,V1_Source,V1_State,V2_Setpoint_%,V2_Actual_%,V2_Source,V2_State,V3_Setpoint_%,V3_Actual_%,V3_Source,V3_State,WaterLevel_mm,WaterLevel_%,Temperature1_C,Temperature2_C$R$N';
        cbLen := INT_TO_UDINT(LEN(sHeader));

        fbFileWrite(
            bExecute   := TRUE,
            hFile      := hFilenumber,
            pWriteBuff := ADR(sHeader),
            cbWriteLen := cbLen);

        IF NOT fbFileWrite.bBusy THEN
            fbFileWrite(bExecute := FALSE);
            IF fbFileWrite.bError THEN
                nErrorCode := fbFileWrite.nErrId;
                bError     := TRUE;
                eState     := E_CSVLogState.CSV_CLOSE;
            ELSE
                eState := E_CSVLogState.CSV_WRITE_ROW;
            END_IF
        END_IF

    (* ----------------------------------------------------------
       CSV_WRITE_ROW — assemble and append one data row.
       Source text is derived from E_ValveSource enum per valve.
       Real sensor values come from stSensors (FB_SensorIO output).
       ---------------------------------------------------------- *)
    E_CSVLogState.CSV_WRITE_ROW:
        (* Build timestamp string: YYYY-MM-DD HH:MM:SS *)
        sTimestamp := SYSTEMTIME_TO_STRING(fbGetTime.systemTime);

        sLine := CONCAT(sTimestamp, ',');

        (* Valve 1 *)
        CASE stValve[1].Source OF
            E_ValveSource.MQTT: sSource := 'MQTT';
            E_ValveSource.HMI:  sSource := 'HMI';
            ELSE                sSource := 'NONE';
        END_CASE
        sLine := CONCAT(sLine, REAL_TO_STRING(stValve[1].Active_Setpoint));  sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, REAL_TO_STRING(stValve[1].Actual_Position));  sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, sSource);                                      sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, INT_TO_STRING(stValve[1].State));             sLine := CONCAT(sLine, ',');

        (* Valve 2 *)
        CASE stValve[2].Source OF
            E_ValveSource.MQTT: sSource := 'MQTT';
            E_ValveSource.HMI:  sSource := 'HMI';
            ELSE                sSource := 'NONE';
        END_CASE
        sLine := CONCAT(sLine, REAL_TO_STRING(stValve[2].Active_Setpoint));  sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, REAL_TO_STRING(stValve[2].Actual_Position));  sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, sSource);                                      sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, INT_TO_STRING(stValve[2].State));             sLine := CONCAT(sLine, ',');

        (* Valve 3 *)
        CASE stValve[3].Source OF
            E_ValveSource.MQTT: sSource := 'MQTT';
            E_ValveSource.HMI:  sSource := 'HMI';
            ELSE                sSource := 'NONE';
        END_CASE
        sLine := CONCAT(sLine, REAL_TO_STRING(stValve[3].Active_Setpoint));  sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, REAL_TO_STRING(stValve[3].Actual_Position));  sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, sSource);                                      sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, INT_TO_STRING(stValve[3].State));             sLine := CONCAT(sLine, ',');

        (* Sensor data — real values from FB_SensorIO, not hardcoded -999 *)
        sLine := CONCAT(sLine, REAL_TO_STRING(stSensors.rWaterLevel_mm));    sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, REAL_TO_STRING(stSensors.rWaterLevel_pct));   sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, REAL_TO_STRING(stSensors.rTemperature_C[1])); sLine := CONCAT(sLine, ',');
        sLine := CONCAT(sLine, REAL_TO_STRING(stSensors.rTemperature_C[2])); sLine := CONCAT(sLine, '$R$N');

        cbLen := INT_TO_UDINT(LEN(sLine));

        fbFileWrite(
            bExecute   := TRUE,
            hFile      := hFilenumber,
            pWriteBuff := ADR(sLine),
            cbWriteLen := cbLen);

        IF NOT fbFileWrite.bBusy THEN
            fbFileWrite(bExecute := FALSE);
            IF fbFileWrite.bError THEN
                nErrorCode := fbFileWrite.nErrId;
                bError     := TRUE;
            ELSE
                bError      := FALSE;
                dtLastWrite := SYSTEMTIME_TO_DT(fbGetTime.systemTime);
            END_IF
            eState := E_CSVLogState.CSV_CLOSE;
        END_IF

    (* ----------------------------------------------------------
       CSV_CLOSE — close the file handle and return to IDLE
       ---------------------------------------------------------- *)
    E_CSVLogState.CSV_CLOSE:
        fbFileClose(hFile := hFilenumber, bExecute := TRUE);
        IF NOT fbFileClose.bBusy THEN
            fbFileClose(bExecute := FALSE);
            hFilenumber := 0;
            eState      := E_CSVLogState.CSV_IDLE;
        END_IF

    (* ----------------------------------------------------------
       CSV_ERROR — I/O error; wait for next trigger to retry
       ---------------------------------------------------------- *)
    E_CSVLogState.CSV_ERROR:
        bBusy  := FALSE;
        bError := TRUE;
        IF NOT bTriggerWrite THEN
            eState := E_CSVLogState.CSV_IDLE;
        END_IF

END_CASE
]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>
