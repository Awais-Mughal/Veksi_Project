s>4992</BitOffs><Default><SubItem><Name>.PORT</Name><Value>10000</Value></SubItem><SubItem><Name>.IDXGRP</Name><Value>133</Value></SubItem></Default><Properties><Property><Name>conditionalshow</Name></Property></Properties></SubItem><SubItem><Name>fbAdsWrite</Name><Type Namespace="Tc2_System">ADSWRITE</Type><BitSize>1344</BitSize><BitOffs>6720</BitOffs><Default><SubItem><Name>.PORT</Name><Value>10000</Value></SubItem><SubItem><Name>.IDXGRP</Name><Value>111</Value></SubItem></Default><Properties><Property><Name>conditionalshow</Name></Property></Properties></SubItem><SubItem><Name>fbTrigger</Name><Type Namespace="Tc2_Standard">R_TRIG</Type><BitSize>128</BitSize><BitOffs>8064</BitOffs><Properties><Property><Name>conditionalshow</Name></Property></Properties></SubItem><SubItem><Name>state</Name><Type>BYTE</Type><BitSize>8</BitSize><BitOffs>8192</BitOffs><Properties><Property><Name>conditionalshow</Name></Property></Properties></SubItem><SubItem><Name>dataEntry</Name><Type Namespace="Tc2_Utilities">ST_AmsFindFileSystemEntry</Type><BitSize>2592</BitSize><BitOffs>8224</BitOffs><Properties><Property><Name>conditionalshow</Name></Property></Properties></SubItem><SubItem><Name>eFindCmd</Name><Type Namespace="Tc2_Utilities">E_EnumCmdType</Type><BitSize>16</BitSize><BitOffs>10816</BitOffs><Properties><Property><Name>conditionalshow</Name></Property></Properties></SubItem><Properties><Property><Name>PouType</Name><Value>FunctionBlock</Value></Property><Property><Name>conditionalshow_all_locals</Name></Property></Properties></DataType><DataType><Name>FB_CsvLogger</Name><Comment><![CDATA[
============================================================
FUNCTION_BLOCK: FB_CsvLogger
============================================================

PURPOSE
  Appends one CSV row per log interval to a monthly log file
  on the IPC local filesystem (C:\TwinCAT\3.1\Boot\Log\).

FILE NAMING
  <sBasePath><sPrefix><YYYY-MM>.csv
  Example: C:\TwinCAT\3.1\Boot\Log\IrrigationLog_2026-04.csv

CSV COLUMNS
  Timestamp, V1_Setpoint_%, V1_Actual_%, V1_Source, V1_State,
  V2_Setpoint_%, V2_Actual_%, V2_Source, V2_State,
  V3_Setpoint_%, V3_Actual_%, V3_Source, V3_State,
  WaterLevel_mm, WaterLevel_%, Temperature1_C, Temperature2_C

STATE MACHINE
  CSV_IDLE       — Waiting for trigger (timer or force write)
  CSV_PREPARE    — Build filename, check if file exists
  CSV_OPEN       — Open file in append mode
  CSV_WRITE_HDR  — Write column header (new file only)
  CSV_WRITE_ROW  — Append one data row
  CSV_CLOSE      — Close file handle
  CSV_ERROR      — I/O error; waits for next trigger to retry

NOTES
  - File I/O FBs are non-blocking; each step may span PLC cycles.
  - bForceWrite forces a row write outside the normal interval.
  - Header is written only on the first write to a new file.

LIBRARIES
  Tc2_Utilities (FB_FileOpen, FB_FileWrite, FB_FileClose, FB_EnumFindFileEntry)
  Tc2_System    (FB_LocalSystemTime)
============================================================
]]></Comment><BitSize>54912</BitSize><SubItem><Name>bEnable</Name><Type>BOOL</Type><Comment><![CDATA[ Master enable; FALSE skips all logging    ]]></Comment><BitSize>8</BitSize><BitOffs>64</BitOffs><Default><Bool>true</Bool></Default><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>bForceWrite</Name><Type>BOOL</Type><Comment><![CDATA[ Rising edge: write a row immediately      ]]></Comment><BitSize>8</BitSize><BitOffs>72</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>tLogInterval</Name><Type>TIME</Type><Comment><![CDATA[ Periodic write interval (e.g. T#15M)      ]]></Comment><BitSize>32</BitSize><BitOffs>96</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>sBasePath</Name><Type>STRING(128)</Type><Comment><![CDATA[ Folder path including trailing backslash  ]]></Comment><BitSize>1032</BitSize><BitOffs>128</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>sPrefix</Name><Type Namespace="Tc2_System">T_MaxString</Type><Comment><![CDATA[ Filename prefix (e.g. 'IrrigationLog_')   ]]></Comment><BitSize>2048</BitSize><BitOffs>1160</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>stValve</Name><Type>ST_ValveData</Type><ArrayInfo><LBound>1</LBound><Elements>3</Elements></ArrayInfo><Comment><![CDATA[ Valve runtime data from GVL_System ]]></Comment><BitSize>1152</BitSize><BitOffs>3264</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></Properties></SubItem><SubItem><Name>stSensors</Name><Type>ST_SensorData</Type><Comment><![CDATA[ Sensor readings from FB_SensorIO          ]]></Comment><BitSize>416</BitSize><BitOffs>4416</BitOffs><Properties><Property><Name>ItemType</Name><Value>Input</Value></Property></